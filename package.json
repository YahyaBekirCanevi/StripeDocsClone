{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bunx @tailwindcss/cli -i src/input.css -o src/index.css --watch\" \"bun --hot src/index.ts\"",
    "build": "bunx @tailwindcss/cli -i src/input.css -o src/index.css --minify && bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@markdoc/markdoc": "^0.5.7",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@tailwindcss/cli": "^4.3.2",
    "concurrently": "^10.0.3",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
